{
  "functions": {
    "source": "InventoryBackend"
  },

  "hosting": [
    {
      "target": "imm",
      "public": "InventoryFrontend/dist",
      "ignore": [
        "firebase.json",
        "**/.*",
        "**/node_modules/**"
      ],
      "rewrites": [
        {
          "source": "/api/**",
          "function": "api"
        },
        {
          "source": "**",
          "destination": "/index.html"
        }
      ]
    }
  ],

  "firestore": {
    "rules": "InventoryBackend/firestore.rules"
  }
}